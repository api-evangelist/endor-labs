            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.endorlabs.com/v1/namespaces/{{namespace}}/policies",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a Policy resource in a namespace."
        },
        {
          "info": {
            "name": "Get a Policy resource by UUID.",
            "type": "http"
          },
          "http": {
